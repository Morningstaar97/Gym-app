rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Testing ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100
            && data.age is string && data.age.size() > 0 && data.age.size() <= 3
            && data.gender in ['homme', 'femme']
            && (!data.keys().contains('experience') || data.experience is string)
            && (!data.keys().contains('equipment') || data.equipment is string)
            && (!data.keys().contains('goal') || data.goal is string)
            && (!data.keys().contains('focus') || data.focus is string);
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) 
                   && (incoming().get('updatedAt', request.time) == request.time);
      allow update: if isOwner(userId) && isValidUser(incoming())
                   && (incoming().updatedAt == request.time)
                   && incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'age', 'gender', 'experience', 'equipment', 'goal', 'focus', 'updatedAt']);
    }

    // --- History ---
    match /users/{userId}/history/{workoutId} {
      function isValidWorkout(data) {
        return data.id is string
            && data.title is string && data.title.size() <= 200
            && (!data.keys().contains('createdAt') || data.createdAt == request.time);
      }
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(workoutId) && isValidWorkout(incoming());
      allow delete: if isOwner(userId);
    }

    // --- Favorites ---
    match /users/{userId}/favorites/{workoutId} {
      function isValidFav(data) {
        return data.id is string
            && data.title is string && data.title.size() <= 200;
      }
      allow list, get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidId(workoutId) && isValidFav(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
