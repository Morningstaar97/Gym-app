{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "age": { "type": "string" },
        "gender": { "type": "string" },
        "experience": { "type": "string" },
        "equipment": { "type": "string" },
        "goal": { "type": "string" },
        "focus": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "age", "gender"]
    },
    "WorkoutPlan": {
      "title": "WorkoutPlan",
      "description": "A generated workout plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "exercises": { "type": "array" },
        "warmup": { "type": "array" },
        "cooldown": { "type": "array" },
        "params": { "type": "object" },
        "isFavorite": { "type": "boolean" },
        "volume": { "type": "number" },
        "avgRpe": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/history/{workoutId}": {
      "schema": "WorkoutPlan",
      "description": "User workout history"
    },
    "/users/{userId}/favorites/{workoutId}": {
      "schema": "WorkoutPlan",
      "description": "User favorite sessions"
    }
  }
}
